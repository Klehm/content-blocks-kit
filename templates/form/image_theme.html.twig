{# Form theme for ImageBlock — wraps the hidden src field with upload UI #}

{% block _content_block_src_row %}
    <div data-controller="cb-file-upload" class="cb-form-row cb-image-upload">
        <label class="cb-form-label">{{ 'cb_kit.block.image.field.file'|trans({}, 'content_blocks_kit') }}</label>
        <input type="file"
               class="cb-form-file"
               accept="image/*"
               data-action="change->cb-file-upload#upload:stop">
        <span data-cb-file-upload-target="status" class="cb-upload-status"></span>

        {% set src = form.vars.value %}
        {% if src %}
            <div class="cb-image-upload__preview">
                <img data-cb-file-upload-target="preview"
                     src="{{ src }}"
                     class="cb-thumbnail">
            </div>
        {% else %}
            <img data-cb-file-upload-target="preview" class="cb-thumbnail" hidden>
        {% endif %}

        {# The hidden input has data-cb-file-upload-target="hiddenInput" via attr in ImageBlock::buildForm() #}
        {{ form_widget(form) }}
    </div>
{% endblock %}
