{# ImageBlock view/preview template.

   No CSS classes here on purpose: this template is rendered on the
   host's front-end (and in the builder's preview iframe), neither of
   which load the admin form stylesheet. Visual styling — beyond the
   max-height ceiling that keeps the preview compact — is the host's
   responsibility. #}
{% if data.src|default %}
    {% set alt = data.alt|default('') %}
    <div class="cb-block-image-preview">
        <img src="{{ data.src }}"
             alt="{{ alt }}"
             style="max-height: 120px; max-width: 100%;">
        {% if alt %}
            <small style="display: block; margin-top: 0.25rem; color: #5b6478;">{{ alt }}</small>
        {% endif %}
    </div>
{% else %}
    <small style="color: #5b6478;">{{ 'cb_kit.block.image.no_image'|trans({}, 'content_blocks_kit') }}</small>
{% endif %}
