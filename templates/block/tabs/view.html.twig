{# TabsBlock — CSS-only tabs (no JS dependency).

   Each tab is driven by a hidden radio input pinned at the root of the
   block. Their `:checked` state toggles the matching panel via sibling
   combinators. Inline `<style>` keeps the rendering self-contained on
   the host's front-end (which does not load the package's admin CSS).
#}
{% if data.tabs is defined and data.tabs is iterable and data.tabs|length > 0 %}
    {% set uid = 'cb-tabs-' ~ random() %}
    <div class="cb-block-tabs" id="{{ uid }}">
        {% for tab in data.tabs %}
            <input type="radio"
                   name="{{ uid }}__state"
                   id="{{ uid }}__r{{ loop.index0 }}"
                   class="cb-block-tabs__radio"
                   data-tab-index="{{ loop.index0 }}"
                   {% if loop.first %}checked{% endif %}>
        {% endfor %}
        <div class="cb-block-tabs__nav" role="tablist">
            {% for tab in data.tabs %}
                <label for="{{ uid }}__r{{ loop.index0 }}" class="cb-block-tabs__tab" role="tab">
                    {{ tab.title|default('Untitled') }}
                </label>
            {% endfor %}
        </div>
        <div class="cb-block-tabs__panels">
            {% for tab in data.tabs %}
                <div class="cb-block-tabs__panel" data-tab-index="{{ loop.index0 }}" role="tabpanel">
                    {{ tab.content|default('')|nl2br }}
                </div>
            {% endfor %}
        </div>
    </div>
    <style>
        .cb-block-tabs { display: block; }
        .cb-block-tabs__radio {
            position: absolute;
            opacity: 0;
            pointer-events: none;
            width: 0; height: 0;
        }
        .cb-block-tabs__nav {
            display: flex;
            flex-wrap: wrap;
            gap: 2px;
            border-bottom: 1px solid #e3e5e9;
        }
        .cb-block-tabs__tab {
            padding: 0.5rem 0.9rem;
            font-size: 0.9rem;
            line-height: 1.3;
            color: #5b6478;
            background: transparent;
            border: 1px solid transparent;
            border-bottom: 0;
            border-top-left-radius: 0.375rem;
            border-top-right-radius: 0.375rem;
            cursor: pointer;
            user-select: none;
            margin-bottom: -1px;
        }
        .cb-block-tabs__tab:hover { color: #1f2330; }
        {# Active tab + matching panel via the sibling :checked selector.
           Each radio is followed by all tabs and all panels (flat layout),
           so we target by data-tab-index matching the radio's index. #}
        {% for tab in data.tabs %}
            #{{ uid }}__r{{ loop.index0 }}:checked ~ .cb-block-tabs__nav .cb-block-tabs__tab:nth-of-type({{ loop.index }}) {
                color: #1f2330;
                background: #fff;
                border-color: #e3e5e9;
            }
            #{{ uid }}__r{{ loop.index0 }}:checked ~ .cb-block-tabs__panels .cb-block-tabs__panel[data-tab-index="{{ loop.index0 }}"] {
                display: block;
            }
        {% endfor %}
        .cb-block-tabs__panel {
            display: none;
            padding: 1rem 0.85rem;
            border: 1px solid #e3e5e9;
            border-top: 0;
            border-bottom-left-radius: 0.375rem;
            border-bottom-right-radius: 0.375rem;
        }
        .cb-block-tabs__tab:focus-visible {
            outline: 2px solid #4f8df9;
            outline-offset: -2px;
        }
    </style>
{% else %}
    <small style="color: #5b6478;">{{ 'cb_kit.block.tabs.empty'|trans({}, 'content_blocks_kit') }}</small>
{% endif %}
