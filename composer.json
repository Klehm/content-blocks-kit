{
    "name": "klehm/content-blocks-kit",
    "description": "Ready-to-use block types for ContentBlocks (Text, Title, Image, Tabs).",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "symfony-bundle", "page-builder", "content-blocks", "blocks"],
    "homepage": "https://github.com/klehm/content-blocks-project",
    "support": {
        "issues": "https://github.com/klehm/content-blocks-project/issues",
        "source": "https://github.com/klehm/content-blocks-kit"
    },
    "authors": [
        {
            "name": "Clément Muller",
            "email": "klehm.muller@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "klehm/content-blocks": "@dev",
        "symfony/form": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/mime": "^6.4 || ^7.0 || ^8.0",
        "symfony/security-csrf": "^6.4 || ^7.0 || ^8.0",
        "symfony/validator": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ContentBlocks\\Kit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContentBlocks\\Kit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "ContentBlocks\\Kit\\ContentBlocksKitBundle"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
